# ============================================
# 友链管理系统 - 环境变量配置示例
# 部署到 Cloudflare Pages 时在 Dashboard 设置
# ============================================

# 博客地址（必填）
# 用于通知邮件中的友链页面链接和 RSS 默认源
# 示例: https://blog.xiaow.qzz.io
BLOG_URL=https://blog.xiaow.qzz.io

# 本站域名（必填）
# 用于 Referer 来源校验，防止 API 被直接调用
# 填你的友链系统域名
# 示例: friends.xiaow.qzz.io
SITE_DOMAIN=friends.xiaow.qzz.io

# Cron 密钥（推荐）
# 用于触发邮件发送的 cron job 鉴权
CRON_SECRET=你的随机密钥

# DeepSeek API Key（可选）
# AI 智能解析功能需要
DEEPSEEK_KEY=sk-your-deepseek-key

# 图床配置（可选）
# 自动上传头像到图仓 https://wp-cdn.4ce.cn
TUCANG_TOKEN=你的图床Token
TUCANG_FOLDER_ID=文件夹ID
